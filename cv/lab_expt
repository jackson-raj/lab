# 10 Program

import cv2,urllib.request,numpy as np
from google.colab.patches import cv2_imshow

u="https://raw.githubusercontent.com/opencv/opencv/master/doc/acircles_pattern.png"
i=cv2.imdecode(np.frombuffer(urllib.request.urlopen(u).read(),np.uint8),1)
g=cv2.cvtColor(i,cv2.COLOR_BGR2GRAY)

p=(4,11)
s=cv2.SimpleBlobDetector_Params()
s.filterByArea=True; s.minArea=20; s.maxArea=50000
s.filterByColor=True; s.blobColor=0
d=cv2.SimpleBlobDetector_create(s)

ok,c=cv2.findCirclesGrid(g,p,cv2.CALIB_CB_ASYMMETRIC_GRID|cv2.CALIB_CB_CLUSTERING,d,cv2.CirclesGridFinderParameters())
print("Detected =",ok)

if ok: cv2.drawChessboardCorners(i,p,c,ok)
cv2_imshow(i)
