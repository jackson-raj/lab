# 8 Program

import cv2,urllib.request,numpy as np
from google.colab.patches import cv2_imshow

u="https://static0.srcdn.com/wordpress/wp-content/uploads/2020/09/Iron-Man-featured-image.jpg"
img=cv2.imdecode(np.frombuffer(urllib.request.urlopen(u).read(),np.uint8),1)

tracker=cv2.TrackerCSRT_create()
tracker.init(img,(100,100,300,300))

ok,b=tracker.update(img)

if ok:
    x,y,w,h=[int(i) for i in b]
    cv2.rectangle(img,(x,y),(x+w,y+h),(0,255,0),3)

cv2.putText(img,"Tracking",(50,50),0,1,(255,0,0),2)

cv2_imshow(img)
