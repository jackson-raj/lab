# 9 Program

import cv2,numpy as np,urllib.request as u
from google.colab.patches import cv2_imshow

url="https://i.pinimg.com/1200x/a9/cb/f1/a9cbf16e2b763b1830000676a0c3b601.jpg"
img=cv2.imdecode(np.frombuffer(u.urlopen(url).read(),np.uint8),1)

m=np.zeros(img.shape[:2],np.uint8)
bg=np.zeros((1,65),np.float64)
fg=np.zeros((1,65),np.float64)

h,w=img.shape[:2]
cv2.grabCut(img,m,(5,5,w-10,h-10),bg,fg,5,0)

out=img*np.where((m==2)|(m==0),0,1).astype("uint8")[:,:,None]

cv2_imshow(out)
